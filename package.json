{
  "name": "litepack",
  "version": "1.0.0",
  "description": "📦 Lightweight binary schema encoding - define a schema, encode to bytes, decode back. Zero dependencies.",
  "main": "./litepack.js",
  "module": "./litepack.mjs",
  "types": "./litepack.d.ts",
  "browser": "./litepack.js",
  "exports": {
    ".": {
      "import": "./litepack.mjs",
      "require": "./litepack.js",
      "types": "./litepack.d.ts",
      "browser": "./litepack.js"
    }
  },
  "files": [
    "litepack.js",
    "litepack.mjs",
    "litepack.d.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
